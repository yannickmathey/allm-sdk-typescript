{
  "name": "@allm/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the ALLM model intelligence API",
  "type": "module",
  "license": "Apache-2.0",
  "author": "ALLM",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yannickmathey/allm-sdk-typescript.git"
  },
  "homepage": "https://github.com/yannickmathey/allm-sdk-typescript#readme",
  "bugs": {
    "url": "https://github.com/yannickmathey/allm-sdk-typescript/issues"
  },
  "keywords": ["allm", "llm", "ai", "models", "pricing", "lifecycle"],
  "sideEffects": false,
  "packageManager": "pnpm@11.7.0",
  "engines": { "node": ">=20" },
  "files": ["dist", "contract", "CHANGELOG.md", "NOTICE"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./package.json": "./package.json"
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src test",
    "scripts:check": "node --check scripts/check-contract.mjs && node --check scripts/check-release-tag.mjs && node --check scripts/pack-dry-run.mjs",
    "contract:check:local": "node scripts/check-contract.mjs ../allm-api/src/openapi/openapi.json",
    "contract:check:upstream": "node scripts/check-contract.mjs https://api.use-allm.com/openapi.json",
    "contract:check:upstream:exact": "node scripts/check-contract.mjs --exact https://api.use-allm.com/openapi.json",
    "release:check-tag": "node scripts/check-release-tag.mjs",
    "verify": "pnpm run lint && pnpm run scripts:check && pnpm run typecheck && pnpm run test && pnpm run build",
    "pack:check": "node scripts/pack-dry-run.mjs",
    "prepack": "pnpm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
